# SiliconV — Android Kernel Configuration
#
# Required kernel config options for running Android on SiliconV.
# Based on Android Common Kernel (android-mainline) defconfig.
#
# Apply on top of arm64 defconfig:
#   make ARCH=arm64 defconfig
#   scripts/kconfig/merge_config.sh .config kernel/configs/android.config

# ── Android Core ──────────────────────────────────
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ANDROID_BINDER_IPC_SELFTEST=n
CONFIG_ANDROID_BINDER_FREEZE=n

# ── Ashmem ────────────────────────────────────────
CONFIG_ASHMEM=y

# ── ION (Legacy, for Android < 12) ────────────────
CONFIG_ION=y
CONFIG_ION_SYSTEM_HEAP=y
CONFIG_ION_CMA_HEAP=y
CONFIG_ION_OF=y

# ── DMABUF Heaps (Modern, for Android 12+) ───────
CONFIG_DMA_SHARED_BUFFER=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y

# ── CMA (Contiguous Memory Allocator) ────────────
CONFIG_CMA=y
CONFIG_CMA_AREAS=7
CONFIG_DMA_CMA=y

# ── Shared Memory ────────────────────────────────
CONFIG_SHMEM=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y

# ── IPC ───────────────────────────────────────────
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y

# ── Namespaces (required by Android) ─────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_SCHED=y
CONFIG_SCHED_TUNE=y

# ── Filesystem ────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS_FS=y

# ── Security ──────────────────────────────────────
CONFIG_SECURITY=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y
CONFIG_SECURITY_SELINUX_DEVELOP=y

# ── Networking ────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y

# ── Virtio (SiliconV devices) ─────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_GPU=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_FS=y
CONFIG_VIRTIO_RNG=y

# ── GPU / Graphics ───────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# ── Input ─────────────────────────────────────────
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_UINPUT=y

# ── Char/Misc Devices ────────────────────────────
CONFIG_MISC_DEVICES=y
CONFIG_HW_RANDOM=y

# ── Power Management ─────────────────────────────
CONFIG_PM=y
CONFIG_SUSPEND=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_FREQ=y

# ── Watchdog ──────────────────────────────────────
CONFIG_WATCHDOG=y
CONFIG_SOFT_WATCHDOG=y

# ── Timer ─────────────────────────────────────────
CONFIG_ARM_ARCH_TIMER=y

# ── GIC ───────────────────────────────────────────
CONFIG_ARM_GIC_V3=y

# ── Serial Console ───────────────────────────────
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# ── Earlycon ─────────────────────────────────────
CONFIG_EARLYCON=y
CONFIG_SERIAL_EARLYCON_ARM_SBSA=y

# ── PSCI ──────────────────────────────────────────
CONFIG_ARM_PSCI_FW=y

# ── SMP ───────────────────────────────────────────
CONFIG_SMP=y
CONFIG_NR_CPUS=8
