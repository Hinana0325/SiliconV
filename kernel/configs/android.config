# SiliconV — Android Kernel Configuration (6.6)
#
# For Android Common Kernel android14-6.6
# Apply on top of arm64 defconfig:
#   make ARCH=arm64 defconfig
#   scripts/kconfig/merge_config.sh .config kernel/configs/android.config

# ── Android Core ──────────────────────────────────
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ANDROID_BINDER_IPC_SELFTEST=n
CONFIG_ANDROID_BINDER_FREEZE=n

# ── Ashmem → migrated to memfd in 6.6 ────────────
# CONFIG_ASHMEM is no longer needed on 6.6+
# Android uses memfd_create() instead
CONFIG_MEMFD=y

# ── ION → DMABUF heaps (6.6 uses heaps only) ────
# CONFIG_ION is removed in 6.6
CONFIG_DMA_SHARED_BUFFER=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y

# ── CMA ───────────────────────────────────────────
CONFIG_CMA=y
CONFIG_CMA_AREAS=7
CONFIG_DMA_CMA=y

# ── Shared Memory / IPC ──────────────────────────
CONFIG_SHMEM=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_TMPFS_XATTR=y
CONFIG_SYSVIPC=y
CONFIG_POSIX_MQUEUE=y

# ── Namespaces ────────────────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# ── Cgroups ───────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_SCHED=y

# ── Filesystem ────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_EXT4_FS_SECURITY=y
CONFIG_EXT4_FS_ENCRYPTION=y
CONFIG_UNICODE=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y
CONFIG_F2FS_FS_ENCRYPTION=y
CONFIG_FUSE_FS=y
CONFIG_OVERLAY_FS=y

# ── Security (SELinux) ────────────────────────────
CONFIG_SECURITY=y
CONFIG_SECURITYFS=y
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_BOOTPARAM=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_AVC_STATS=y
CONFIG_SECURITY_SELINUX_CHECKREQPROT_VALUE=0
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y
CONFIG_DEFAULT_SECURITY_SELINUX=y
CONFIG_LSM="selinux,landlock,lockdown,yama,loadpin,safesetid,bpf"

# ── Networking ────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y

# ── Virtio (SiliconV devices) ─────────────────────
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_GPU=y
CONFIG_VIRTIO_INPUT=y
CONFIG_VIRTIO_FS=y
CONFIG_VIRTIO_RNG=y

# ── GPU / Graphics ───────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_VIRTIO_GPU_KMS=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# ── Input ─────────────────────────────────────────
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_UINPUT=y

# ── Char/Misc ─────────────────────────────────────
CONFIG_MISC_DEVICES=y
CONFIG_HW_RANDOM=y

# ── Power ─────────────────────────────────────────
CONFIG_PM=y
CONFIG_SUSPEND=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_FREQ=y

# ── Watchdog ──────────────────────────────────────
CONFIG_WATCHDOG=y
CONFIG_SOFT_WATCHDOG=y

# ── Timer / GIC / Serial ─────────────────────────
CONFIG_ARM_ARCH_TIMER=y
CONFIG_ARM_GIC_V3=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# ── Earlycon / PSCI / SMP ────────────────────────
CONFIG_EARLYCON=y
CONFIG_SERIAL_EARLYCON_ARM_SBSA=y
CONFIG_ARM_PSCI_FW=y
CONFIG_SMP=y
CONFIG_NR_CPUS=8

# ── 6.6-specific: userfaultfd (Android needs this) ─
CONFIG_USERFAULTFD=y

# ── Networking: PPP, PPPoE (Android VPN) ──────────
CONFIG_PPP=y
CONFIG_PPP_ASYNC=y
CONFIG_PPP_SYNC_TTY=y
CONFIG_PPP_DEFLATE=y
CONFIG_PPP_BSDCOMP=y
CONFIG_PPP_MPPE=y
CONFIG_PPPOE=y
CONFIG_PPPOLAC=y
CONFIG_PPPOPNS=y
CONFIG_PPTP=y
CONFIG_PPPOL2TP=y

# ── Networking: IPv6 (Android requires IPv6) ──────
CONFIG_IPV6=y
CONFIG_IPV6_ROUTER_PREF=y
CONFIG_IPV6_ROUTE_INFO=y
CONFIG_IPV6_OPTIMISTIC_DAD=y
CONFIG_IPV6_MIP6=y
CONFIG_IPV6_NDISC_NODETYPE=y
CONFIG_IPV6_MULTIPLE_TABLES=y
CONFIG_IPV6_SUBTREES=y

# ── Networking: Bridge / Netfilter ────────────────
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NF_NAT=y
CONFIG_NF_NAT_REDIRECT=y
CONFIG_NF_NAT_MASQUERADE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_NETFILTER_XT_TARGET_LOG=y
CONFIG_NETFILTER_XT_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y

# ── Kernel features needed by Android ─────────────
CONFIG_SWAP=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_SYNCHRONIZE_RCU=y
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# ── Android rmnet data (forwarding) ───────────────
CONFIG_NETFILTER_TPROXY=y
CONFIG_NETFILTER_XT_MATCH_SOCKET=y

# Device Mapper (required by Android AVB/dm-verity)
CONFIG_BLK_DEV_DM=y
CONFIG_DM_VERITY=y
CONFIG_DM_CRYPT=y
CONFIG_DM_ZERO=y
CONFIG_DM_MIRROR=y
