# SiliconV — Git Attributes
#
# Normalize text files to LF in the repository.
# Windows batch files need CRLF on checkout.

*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

*.c      text eol=lf
*.h      text eol=lf
*.m      text eol=lf
*.S      text eol=lf
*.cpp    text eol=lf
*.mm     text eol=lf
*.cmake  text eol=lf
*.sh     text eol=lf diff=shell
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf diff=markdown
*.txt    text eol=lf
*.te     text eol=lf

*.icns   binary
*.bin    binary
*.raw    binary
*.img    binary
*.qcow2  binary
*.iso    binary
*.gz     binary
*.xz     binary
*.zip    binary
*.png    binary
*.icns   binary
*.svg    diff=text

# Git diff for shell scripts
*.sh     diff=shell

# Always use LF for the repository
*         text=auto
